# ── WAJIB DIISI ──────────────────────────

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=db_wa_blast

# JWT secret (minimal 32 karakter random)
JWT_SECRET=buat_string_random_minimal_32_karakter_disini
# Login superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123

# ── LISENSI (dari ngertikode.id) ──────────

LICENSE_KEY=
LICENSE_API_URL=https://api.ngertikode.id
LICENSE_API_SECRET=

# ── OPSIONAL ──────────────────────────────

PORT=3030
DB_PATH=./wa-assistant.db
CORS_ALLOWED_ORIGINS=*
TOKEN_TTL_HOURS=24
LOGIN_WINDOW_MIN=10
LOGIN_LOCK_MIN=10
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
MEDIA_RETENTION_DAYS=30

# Embedding untuk semantic search (opsional)
# Kosongkan EMBEDDING_API_KEY untuk nonaktif (fallback keyword match)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

RAJAONGKIR_API_KEY=
